# === GTM Copilot — Variables d'environnement ===
# Copie ce fichier en `.env` et remplis avec tes valeurs.
# Voir `docs/SETUP.md` pour le guide d'install complet.

# === Unipile (passerelle LinkedIn + email) ===
# Récupère ces valeurs dans le Dashboard Unipile (Settings > API).
# Le DSN doit inclure le scheme https://.
UNIPILE_DSN=https://api17.unipile.com:14708
UNIPILE_API_KEY=

# Un account_id PAR provider connecté (Unipile en cree un par OAuth).
# Récupère chaque account_id apres l'OAuth correspondant
# (voir docs/operators/unipile-outlook.md pour la procédure).
UNIPILE_LINKEDIN_ACCOUNT_ID=
UNIPILE_OUTLOOK_ACCOUNT_ID=
# UNIPILE_GMAIL_ACCOUNT_ID=

# Fallback global si tu n'as qu'un seul provider connecte (ex : LinkedIn seul).
# Si UNIPILE_LINKEDIN_ACCOUNT_ID ou UNIPILE_OUTLOOK_ACCOUNT_ID sont definis,
# ils ont priorite sur cette variable.
# UNIPILE_ACCOUNT_ID=

# === CRM ===
# Choisis ton CRM : airtable, notion, nocodb, ou custom
CRM_TYPE=airtable

# --- Airtable ---
# Voir docs/crm/airtable.md
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_ID=

# --- Notion ---
# Voir docs/crm/notion.md
# NOTION_API_KEY=
# NOTION_DATABASE_ID=

# --- NocoDB ---
# Voir docs/crm/nocodb.md
# NOCODB_URL=
# NOCODB_TOKEN=
# NOCODB_TABLE_ID=

# --- Custom ---
# Voir docs/crm/custom.md
# CRM_CUSTOM_API_URL=
# CRM_CUSTOM_API_KEY=

# === Enrichissement (optionnel) ===
# FullEnrich pour récupérer mails/téléphones depuis LinkedIn
# FULLENRICH_API_KEY=
